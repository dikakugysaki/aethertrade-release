@echo offtitle AetherTrade AI - Auto Installer v2.0color 0Aecho.echo ╔══════════════════════════════════════════════╗echo ║     AETHER TRADE AI - AUTO INSTALLER v2.0    ║echo ║     1-KLIK AUTO INSTALL + SETUP              ║echo ╚══════════════════════════════════════════════╝echo.:: ============================================:: KONFIGURASI - ADMIN EDIT DI SINI:: ============================================set "EA_URL=https://raw.githubusercontent.com/dikakugysaki/aethertrade-release/main/AetherTrade_Agent.ex5"set "EA_FILENAME=AetherTrade_Agent.ex5"set "EA_PRESET_NAME=AetherTrade_Agent":: Default License - User bisa ganti nantiset "DEFAULT_LICENSE=AT-USERKEYANDA"set "TELEGRAM_TOKEN=8532463057:AAENhEzEK2u6OcgHS2MWDy__wiSZF8OBlFY"set "TELEGRAM_CHANNEL=-1003643016845":: ============================================:: DETEKSI FOLDER MT5:: ============================================echo [1/6] Detecting MT5 folder...set "MT5_FOUND="for /d %%i in ("%APPDATA%\MetaQuotes\Terminal\*") do (    if exist "%%i\MQL5\Experts\" (        set "MT5_FOLDER=%%i"        set "EXPERTS=%%i\MQL5\Experts"        set "FILES=%%i\Files"        set "PROFILES=%%i\Profiles"        set "MT5_FOUND=1"        echo       Found: %%i    ))if not defined MT5_FOUND (    echo ❌ MetaTrader 5 not found!    echo    Please install MT5 first.    pause    exit /b):: ============================================:: DOWNLOAD EA:: ============================================echo.echo [2/6] Downloading EA...powershell -Command "[Net.ServicePointManager]::SecurityProtocol = [Net.SecurityProtocolType]::Tls12; Invoke-WebRequest -Uri '%EA_URL%' -OutFile '%TEMP%\%EA_FILENAME%'" 2>nulif exist "%TEMP%\%EA_FILENAME%" (    echo       ✅ Downloaded successfully!) else (    echo       ❌ Download failed! Check internet connection.    pause    exit /b):: ============================================:: INSTALL EA:: ============================================echo.echo [3/6] Installing EA...copy /Y "%TEMP%\%EA_FILENAME%" "%EXPERTS%\" >nul 2>&1if exist "%EXPERTS%\%EA_FILENAME%" (    echo       ✅ EA installed to MQL5\Experts\) else (    echo       ❌ Failed to copy EA!    pause    exit /b):: ============================================:: CREATE PRESET (.set):: ============================================echo.echo [4/6] Creating EA preset...(echo ; AetherTrade AI - Auto Presetecho LicenseKey=%DEFAULT_LICENSE%echo TelegramToken=%TELEGRAM_TOKEN%echo TelegramChannelID=%TELEGRAM_CHANNEL%echo ServerURL=http://127.0.0.1:8888echo CheckInterval=2echo DefaultLot=0.01echo MaxPositions=80echo MaxBuyPositions=40echo MaxSellPositions=40echo MagicNumber=123456echo EnableTrailing=trueecho TrailMode=0echo ShowPanel=trueecho DebugMode=trueecho AllowedPairs=BTCUSDm) > "%EXPERTS%\%EA_PRESET_NAME%.set"echo       ✅ Preset created: %EA_PRESET_NAME%.set:: ============================================:: CREATE WHITELIST REMINDER:: ============================================echo.echo [5/6] Creating whitelist reminder...if not exist "%FILES%" mkdir "%FILES%"(echo ═══════════════════════════════════════echo   WHITELIST URL UNTUK EA AETHER TRADEecho ═══════════════════════════════════════echo.echo Tambahkan URL ini di MT5:echo   Tools ^> Options ^> Expert Advisorsecho   Allow WebRequest for listed URL:echo.echo   https://api.telegram.orgecho   http://127.0.0.1:8888echo.echo ═══════════════════════════════════════) > "%FILES%\AetherTrade_Whitelist.txt"echo       ✅ Whitelist guide saved!:: ============================================:: CREATE SETUP GUIDE:: ============================================echo.echo [6/6] Creating setup guide...(echo ╔══════════════════════════════════════════════╗echo ║   AETHER TRADE AI - SETUP GUIDE              ║echo ╚══════════════════════════════════════════════╝echo.echo ✅ EA SUDAH TERINSTALL!echo.echo 📋 LANGKAH SELANJUTNYA:echo.echo 1. BUKA MT5echo    - Login ke akun trading Andaecho.echo 2. REFRESH NAVIGATORecho    - Tekan Ctrl+Necho    - Klik kanan Expert Advisors ^> Refreshecho    - Cari "%EA_FILENAME%"echo.echo 3. ATTACH EA KE CHARTecho    - Buka chart BTCUSDmecho    - Drag EA dari Navigator ke chartecho    - Klik "Load" dan pilih preset:echo      %EA_PRESET_NAME%.setecho    - Ganti LicenseKey dengan milik Andaecho    - Klik OKecho.echo 4. WHITELIST URL (WAJIB!)echo    - Tools ^> Options ^> Expert Advisorsecho    - Centang: Allow WebRequestecho    - Tambah: https://api.telegram.orgecho    - Tambah: http://127.0.0.1:8888echo.echo 5. AKTIFKAN AUTOTRADINGecho    - Klik tombol Algo Trading di toolbarecho    - Pastikan warna HIJAUecho.echo 6. JOIN CHANNEL (OPSIONAL)echo    - @SinyalbotAether untuk lihat sinyalecho.echo ═══════════════════════════════════════════════echo 📞 Support: @rimuru_genkaiecho ═══════════════════════════════════════════════) > "%FILES%\AetherTrade_Setup_Guide.txt"echo       ✅ Setup guide saved!:: ============================================:: CLEANUP:: ============================================if exist "%TEMP%\%EA_FILENAME%" del "%TEMP%\%EA_FILENAME%":: ============================================:: DONE:: ============================================echo.echo ╔══════════════════════════════════════════════╗echo ║                                              ║echo ║   ✅ INSTALLATION 100%% COMPLETE!             ║echo ║                                              ║echo ╚══════════════════════════════════════════════╝echo.echo 📂 EA Location: %EXPERTS%\%EA_FILENAME%echo 📂 Preset: %EXPERTS%\%EA_PRESET_NAME%.setecho 📂 Setup Guide: %FILES%\AetherTrade_Setup_Guide.txtecho 📂 Whitelist: %FILES%\AetherTrade_Whitelist.txtecho.echo 🚀 Buka MT5 sekarang dan ikuti panduan di atas!echo.pause